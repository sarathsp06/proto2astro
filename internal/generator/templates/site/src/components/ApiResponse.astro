---
/**
 * ApiResponse: Compact inline property list for response fields.
 * Generated by proto2astro.
 */
import type { Field } from '../data/api/types';

interface Props {
  fields: Field[];
  title?: string;
}

const { fields, title = 'Response' } = Astro.props;
---

{fields.length > 0 && (
  <div class="api-fields">
    <h4 class="api-fields-title">{title}</h4>
    <div class="api-fields-list">
      {fields.map((field) => (
        <div class="api-field">
          <div class="api-field-header">
            <code class="api-field-name">{field.name}</code>
            <span class="api-field-type">{field.type}</span>
          </div>
          <p class="api-field-description">{field.description}</p>
        </div>
      ))}
    </div>
  </div>
)}
