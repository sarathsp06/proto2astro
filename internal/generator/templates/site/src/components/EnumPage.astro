---
/**
 * EnumPage: Renders a dedicated documentation page for a proto enum.
 * Shows all enum values with their numeric codes and descriptions,
 * plus which services reference this enum.
 *
 * Generated by proto2astro.
 */
import type { ApiEnum } from '../data/api/types';

type Props = ApiEnum;

const { name, description, values, usedBy } = Astro.props;
const pkg = Astro.props.package || '';
---

<p>{description}</p>

<div class="enum-section">
  <h2 class="enum-values-heading">Values</h2>

  <table class="enum-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Number</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      {values.map((v) => (
        <tr>
          <td>
            <code class="enum-value-name">{v.name}</code>
          </td>
          <td class="enum-value-number">{v.number}</td>
          <td class="enum-value-desc">{v.description || '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

{usedBy && usedBy.length > 0 && (
  <div class="enum-used-by">
    <h3>Used by</h3>
    <ul>
      {usedBy.map((svc) => (
        <li><code>{svc}</code></li>
      ))}
    </ul>
  </div>
)}

<style>
  .enum-section {
    margin: 1.5rem 0;
  }

  .enum-values-heading {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .enum-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 0.5rem 0 1.5rem;
  }

  .enum-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--sl-color-gray-5);
    font-weight: 600;
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .enum-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
    vertical-align: top;
  }

  .enum-value-name {
    font-family: var(--sl-font-mono);
    font-size: 0.825rem;
    font-weight: 600;
    color: var(--sl-color-white);
    background: transparent;
    padding: 0;
  }

  .enum-value-number {
    font-family: var(--sl-font-mono);
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
  }

  .enum-value-desc {
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  .enum-used-by {
    margin-top: 1.5rem;
  }

  .enum-used-by h3 {
    margin-bottom: 0.5rem;
  }

  .enum-used-by ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .enum-used-by li code {
    font-size: 0.8rem;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-accent-high);
  }
</style>
