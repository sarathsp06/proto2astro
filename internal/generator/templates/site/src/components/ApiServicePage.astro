---
/**
 * ApiServicePage: Renders an entire API service page from a data object.
 * Scalar-inspired two-column layout: info/fields on left, auto-generated
 * curl + response JSON on right. Code examples are built automatically
 * from field `example` values.
 *
 * Generated by proto2docs.
 */
import { Code } from 'astro:components';
import { marked } from 'marked';
import ApiEndpoint from './ApiEndpoint.astro';
import ApiRequest from './ApiRequest.astro';
import ApiResponse from './ApiResponse.astro';
import ErrorCodes from './ErrorCodes.astro';
import type { ApiService, Field } from '../data/api/types';

type Props = ApiService;

const { service, description, notes, rpcs, footer } = Astro.props;
const pkg = Astro.props.package || service;

const DEFAULT_HOST = 'localhost:8080';

// Render optional markdown sections
const notesHtml = notes ? await marked.parse(notes) : '';
const footerHtml = footer ? await marked.parse(footer) : '';

/**
 * Build a nested object from flat dot-notation field names + example values.
 */
function buildExampleObject(fields: Field[]): Record<string, unknown> {
  const obj: Record<string, unknown> = {};
  for (const f of fields) {
    if (f.example === undefined) continue;
    const parts = f.name.split('.');
    let current: Record<string, unknown> = obj;
    for (let i = 0; i < parts.length - 1; i++) {
      const key = parts[i].replace('[]', '');
      if (!(key in current) || typeof current[key] !== 'object' || current[key] === null) {
        current[key] = {};
      }
      current = current[key] as Record<string, unknown>;
    }
    current[parts[parts.length - 1]] = f.example;
  }
  return obj;
}

/**
 * Generate a curl command for a Connect-RPC endpoint.
 */
function generateCurl(packageName: string, serviceName: string, rpcName: string, requestFields: Field[]): string {
  const url = `http://${DEFAULT_HOST}/${packageName}.${serviceName}/${rpcName}`;
  const body = buildExampleObject(requestFields);
  const hasBody = Object.keys(body).length > 0;

  if (!hasBody) {
    return `curl -X POST ${url} \\
  -H "Content-Type: application/json" \\
  -d '{}'`;
  }

  const json = JSON.stringify(body, null, 2);
  return `curl -X POST ${url} \\
  -H "Content-Type: application/json" \\
  -d '${json}'`;
}

/**
 * Generate example response JSON from response fields.
 */
function generateResponseJson(responseFields: Field[]): string | null {
  const body = buildExampleObject(responseFields);
  if (Object.keys(body).length === 0) return null;
  return JSON.stringify(body, null, 2);
}
---

{/* Hostname switcher */}
<div class="api-host-switcher">
  <label class="api-host-label" for="api-host-input">Base URL</label>
  <div class="api-host-input-wrap">
    <button type="button" id="api-protocol-toggle" class="api-host-protocol-btn">http://</button>
    <input
      type="text"
      id="api-host-input"
      class="api-host-input"
      value={DEFAULT_HOST}
      spellcheck="false"
      autocomplete="off"
    />
  </div>
</div>

<p>{description}</p>

{notesHtml && <div class="api-markdown-section" set:html={notesHtml} />}

{rpcs.map((rpc, idx) => {
  const curl = generateCurl(pkg, service, rpc.name, rpc.request);
  const responseJson = rpc.response ? generateResponseJson(rpc.response) : null;

  return (
    <>
      <div class="api-rpc-section" id={rpc.name.toLowerCase()}>
        <div class="api-rpc-columns">
          {/* LEFT COLUMN: endpoint info + fields */}
          <div class="api-rpc-info">
            <h2 class="api-rpc-heading">{rpc.name}</h2>

            <ApiEndpoint
              method="POST"
              path={`/${pkg}.${service}/${rpc.name}`}
              description={rpc.description}
            />

            {rpc.request.length > 0 && (
              <ApiRequest fields={rpc.request} />
            )}

            {rpc.response && rpc.response.length > 0 && (
              <ApiResponse fields={rpc.response} />
            )}

            {rpc.errors && rpc.errors.length > 0 && (
              <ErrorCodes codes={rpc.errors} />
            )}
          </div>

          {/* RIGHT COLUMN: auto-generated code examples */}
          <div class="api-rpc-examples">
            <div class="api-code-panel">
              <div class="api-code-panel-header">Request</div>
              <Code code={curl} lang="bash" />
            </div>

            {responseJson && (
              <div class="api-code-panel">
                <div class="api-code-panel-header">Response</div>
                <Code code={responseJson} lang="json" />
              </div>
            )}
          </div>
        </div>
      </div>

      {idx < rpcs.length - 1 && <hr class="api-rpc-divider" />}
    </>
  );
})}

{footerHtml && (
  <>
    <hr class="api-rpc-divider" />
    <div class="api-markdown-section" set:html={footerHtml} />
  </>
)}

<script define:vars={{ DEFAULT_HOST }}>
  const input = document.getElementById('api-host-input');
  const protocolBtn = document.getElementById('api-protocol-toggle');
  let currentProtocol = sessionStorage.getItem('proto2docs-api-protocol') || 'http://';

  if (protocolBtn) {
    protocolBtn.textContent = currentProtocol;
  }

  if (input) {
    const savedHost = sessionStorage.getItem('proto2docs-api-host');
    if (savedHost) {
      input.value = savedHost;
    }

    if (savedHost || currentProtocol !== 'http://') {
      replaceAllUrls(currentProtocol, input.value.trim() || DEFAULT_HOST);
    }

    input.addEventListener('input', () => {
      const newHost = input.value.trim();
      if (!newHost) return;
      sessionStorage.setItem('proto2docs-api-host', newHost);
      replaceAllUrls(currentProtocol, newHost);
    });
  }

  if (protocolBtn) {
    protocolBtn.addEventListener('click', () => {
      currentProtocol = currentProtocol === 'http://' ? 'https://' : 'http://';
      protocolBtn.textContent = currentProtocol;
      sessionStorage.setItem('proto2docs-api-protocol', currentProtocol);
      const host = input ? input.value.trim() || DEFAULT_HOST : DEFAULT_HOST;
      replaceAllUrls(currentProtocol, host);
    });
  }

  function replaceAllUrls(protocol, host) {
    const codeEls = document.querySelectorAll('.api-code-panel pre code');
    codeEls.forEach((el) => {
      walkTextNodes(el, (text) => {
        return text.replace(
          /https?:\/\/[^/\s]+\//g,
          `${protocol}${host}/`
        );
      });
    });
  }

  function walkTextNodes(el, transform) {
    if (el.nodeType === Node.TEXT_NODE) {
      const newText = transform(el.textContent);
      if (newText !== el.textContent) {
        el.textContent = newText;
      }
    } else {
      el.childNodes.forEach((child) => walkTextNodes(child, transform));
    }
  }
</script>

<style>
  .api-host-switcher {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  .api-host-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
  }

  .api-host-input-wrap {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 0;
    font-family: var(--sl-font-mono);
    font-size: 0.825rem;
  }

  .api-host-protocol-btn {
    color: var(--sl-color-accent);
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--sl-font-mono);
    font-size: 0.825rem;
    padding: 0;
    white-space: nowrap;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
  }

  .api-host-protocol-btn:hover {
    color: var(--sl-color-white);
  }

  .api-host-input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    background: transparent;
    color: var(--sl-color-white);
    font-family: var(--sl-font-mono);
    font-size: 0.825rem;
    padding: 0.2rem 0;
  }

  .api-host-input:focus {
    border-bottom: 1px solid var(--sl-color-accent);
  }

  .api-rpc-section {
    scroll-margin-top: 2rem;
  }

  .api-rpc-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 72rem) {
    .api-rpc-columns {
      grid-template-columns: 1fr;
    }
  }

  .api-rpc-heading {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .api-rpc-examples {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 2rem;
  }

  .api-code-panel {
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }

  .api-code-panel-header {
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-gray-6);
  }

  .api-code-panel :global(pre) {
    margin: 0 !important;
    border-radius: 0 !important;
    border: none !important;
    font-size: 0.8rem !important;
  }

  .api-rpc-divider {
    margin: 2.5rem 0;
    border: none;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .api-markdown-section :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin: 1rem 0;
  }

  .api-markdown-section :global(th) {
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid var(--sl-color-gray-5);
    font-weight: 600;
    color: var(--sl-color-gray-2);
  }

  .api-markdown-section :global(td) {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  .api-markdown-section :global(code) {
    font-size: 0.8rem;
    padding: 0.1rem 0.3rem;
    border-radius: 0.2rem;
    background: var(--sl-color-gray-6);
  }

  .api-markdown-section :global(pre) {
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    background: var(--sl-color-gray-6);
    margin: 1rem 0;
  }

  .api-markdown-section :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .api-markdown-section :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
</style>
